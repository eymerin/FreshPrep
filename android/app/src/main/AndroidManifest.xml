<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">

        <activity
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|smallestScreenSize|screenLayout|uiMode"
            android:name=".MainActivity"
            android:label="@string/title_activity_main"
            android:theme="@style/AppTheme.NoActionBarLaunch"
            android:launchMode="singleTask"
            android:exported="true">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

        </activity>

        <!-- Today's Schedule widget -->
        <receiver
            android:name=".TodayWidgetProvider"
            android:exported="true"
            android:label="@string/widget_today_description">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_today_info" />
        </receiver>

        <!-- Widget action receiver (mark eaten + toggle shopping) -->
        <receiver
            android:name=".WidgetActionReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.freshprep.app.ACTION_MARK_EATEN" />
                <action android:name="com.freshprep.app.ACTION_TOGGLE_SHOPPING" />
            </intent-filter>
        </receiver>

        <!-- Shopping List widget -->
        <receiver
            android:name=".ShoppingWidgetProvider"
            android:exported="true"
            android:label="@string/widget_shopping_description">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_shopping_info" />
        </receiver>

        <!-- RemoteViewsService for shopping list items -->
        <service
            android:name=".ShoppingWidgetService"
            android:exported="false"
            android:permission="android.permission.BIND_REMOTEVIEWS" />

        <!-- Quick Glance widget -->
        <receiver
            android:name=".GlanceWidgetProvider"
            android:exported="true"
            android:label="@string/widget_glance_description">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_glance_info" />
        </receiver>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths"></meta-data>
        </provider>
    </application>

    <!-- Permissions -->

    <uses-permission android:name="android.permission.INTERNET" />
</manifest>
